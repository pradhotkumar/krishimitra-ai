# KrishiMitra AI - Environment Variables Template
# Copy this file to .env.local for development
# Never commit .env or .env.local to version control

# ==============================================
# NEXT.JS PUBLIC VARIABLES (Exposed to Browser)
# ==============================================
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_API_URL=http://localhost:3000/api

# ==============================================
# AWS CONFIGURATION
# ==============================================
AWS_REGION=ap-south-1
AWS_ACCESS_KEY_ID=your_aws_access_key_here
AWS_SECRET_ACCESS_KEY=your_aws_secret_key_here

# Amazon Connect
CONNECT_INSTANCE_ID=your_connect_instance_id
CONNECT_CONTACT_FLOW_ID=your_contact_flow_id

# Amazon Lex
LEX_BOT_ID=your_lex_bot_id
LEX_BOT_ALIAS_ID=your_lex_bot_alias_id
LEX_LOCALE_ID=hi_IN

# Amazon Polly
POLLY_VOICE_ID=Aditi
POLLY_ENGINE=neural

# Amazon Transcribe
TRANSCRIBE_LANGUAGE_CODE=hi-IN

# DynamoDB Tables
DYNAMODB_USERS_TABLE=krishimitra-users
DYNAMODB_SESSIONS_TABLE=krishimitra-sessions
DYNAMODB_PRODUCTS_TABLE=krishimitra-products
DYNAMODB_ORDERS_TABLE=krishimitra-orders
DYNAMODB_CROPS_TABLE=krishimitra-crops

# S3 Buckets
S3_DATA_BUCKET=krishimitra-data
S3_UPLOADS_BUCKET=krishimitra-uploads

# ==============================================
# EXTERNAL APIs
# ==============================================

# Weather API (OpenWeatherMap or similar)
WEATHER_API_KEY=your_weather_api_key
WEATHER_API_URL=https://api.openweathermap.org/data/2.5

# Market Price API
MARKET_API_KEY=your_market_api_key
MARKET_API_URL=https://api.data.gov.in

# ==============================================
# AUTHENTICATION & SECURITY
# ==============================================
NEXTAUTH_SECRET=your_nextauth_secret_here_min_32_chars
NEXTAUTH_URL=http://localhost:3000

# JWT Secret
JWT_SECRET=your_jwt_secret_here

# ==============================================
# OPTIONAL SERVICES
# ==============================================

# Analytics
NEXT_PUBLIC_GA_ID=G-XXXXXXXXXX

# Error Tracking (Sentry)
SENTRY_DSN=your_sentry_dsn

# Email Service (SendGrid, SES, etc.)
EMAIL_FROM=noreply@krishimitra.ai
SENDGRID_API_KEY=your_sendgrid_api_key

# SMS Service (Twilio, SNS, etc.)
TWILIO_ACCOUNT_SID=your_twilio_account_sid
TWILIO_AUTH_TOKEN=your_twilio_auth_token
TWILIO_PHONE_NUMBER=+1234567890

# ==============================================
# DEVELOPMENT SETTINGS
# ==============================================
NODE_ENV=development
LOG_LEVEL=info
